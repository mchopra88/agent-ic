<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% if title %}{{ title }} — agent-ic{% else %}agent-ic{% endif %}</title>
  <meta name="description" content="{% if description %}{{ description }}{% else %}Private technology studio. Seven years of AI-native brokerage infrastructure.{% endif %}">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400;1,600;1,700&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    html {
      font-size: 19px;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }

    body {
      background: #000;
      color: #e8e4de;
      font-family: 'Cormorant Garamond', Georgia, serif;
      font-weight: 400;
      line-height: 1.75;
    }

    .container {
      max-width: 680px;
      margin: 0 auto;
      padding: 3rem 1.5rem 6rem;
    }

    /* — Wordmark — */
    .wordmark {
      font-size: 2.4rem;
      letter-spacing: -0.02em;
      line-height: 1;
      margin-bottom: 0.2rem;
    }
    .wordmark a {
      text-decoration: none;
      color: #e8e4de;
    }
    .wordmark-agent {
      font-weight: 700;
    }
    .wordmark-ic {
      font-weight: 700;
      font-style: italic;
    }

    /* — Nav — */
    nav {
      margin-top: 0.6rem;
      margin-bottom: 4rem;
      font-size: 0.85rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }
    nav a {
      color: #999;
      text-decoration: none;
      margin-right: 2rem;
      transition: color 0.2s;
    }
    nav a:hover, nav a.active {
      color: #e8e4de;
    }

    /* — Typography — */
    h1 {
      font-size: 2rem;
      font-weight: 700;
      line-height: 1.2;
      margin-bottom: 2rem;
      color: #e8e4de;
    }
    h2 {
      font-size: 1.4rem;
      font-weight: 600;
      margin-top: 3rem;
      margin-bottom: 1rem;
      color: #e8e4de;
    }
    p {
      margin-bottom: 1.4rem;
    }
    a {
      color: #e8e4de;
      text-decoration: underline;
      text-underline-offset: 3px;
      text-decoration-color: #555;
    }
    a:hover {
      text-decoration-color: #e8e4de;
    }

    /* — Home thesis — */
    .thesis {
      margin-top: 1rem;
    }
    .thesis p {
      font-size: 1.15rem;
      line-height: 1.8;
    }

    /* — Essay list — */
    .essay-list {
      list-style: none;
    }
    .essay-list li {
      margin-bottom: 2.4rem;
    }
    .essay-list a {
      font-size: 1.3rem;
      font-weight: 600;
      text-decoration: none;
      line-height: 1.3;
      display: block;
    }
    .essay-list a:hover {
      text-decoration: underline;
      text-underline-offset: 4px;
      text-decoration-color: #555;
    }
    .essay-meta {
      font-size: 0.85rem;
      color: #666;
      margin-top: 0.3rem;
      font-style: italic;
    }

    /* — Essay page — */
    .essay-body {
      font-size: 1.1rem;
      line-height: 1.85;
    }
    .essay-body p {
      margin-bottom: 1.5rem;
    }
    .coming-soon {
      color: #666;
      font-style: italic;
      margin-top: 2rem;
      padding-top: 2rem;
      border-top: 1px solid #222;
    }

    /* — Assets — */
    .asset {
      margin-bottom: 3rem;
      padding-bottom: 2rem;
      border-bottom: 1px solid #1a1a1a;
    }
    .asset:last-child {
      border-bottom: none;
    }
    .asset h2 {
      margin-top: 0;
      font-size: 1.25rem;
    }
    .asset p {
      color: #b0aca6;
      font-size: 1.05rem;
    }

    /* — About — */
    .about p {
      font-size: 1.1rem;
      line-height: 1.85;
    }
    .contact {
      margin-top: 3rem;
      padding-top: 2rem;
      border-top: 1px solid #222;
      font-size: 1rem;
      color: #999;
    }
    .contact a {
      color: #e8e4de;
    }

    /* — Footer — */
    footer {
      margin-top: 6rem;
      padding-top: 2rem;
      border-top: 1px solid #111;
      font-size: 0.8rem;
      color: #444;
    }

    /* — Private essay gate — */
    .private-gate {
      position: relative;
    }
    .private-gate .essay-body {
      filter: blur(8px);
      user-select: none;
      pointer-events: none;
      transition: filter 0.5s ease;
    }
    .private-gate.unlocked .essay-body {
      filter: none;
      user-select: auto;
      pointer-events: auto;
    }
    .gate-overlay {
      position: absolute;
      top: 8rem;
      left: 50%;
      transform: translateX(-50%);
      background: rgba(0,0,0,0.85);
      border: 1px solid #333;
      padding: 2.5rem;
      text-align: center;
      z-index: 10;
      max-width: 420px;
      width: 90%;
    }
    .gate-overlay h3 {
      font-size: 1.1rem;
      font-weight: 600;
      margin-bottom: 0.8rem;
      color: #e8e4de;
    }
    .gate-overlay p {
      font-size: 0.9rem;
      color: #888;
      margin-bottom: 1.5rem;
      line-height: 1.6;
    }
    .gate-overlay input {
      background: #111;
      border: 1px solid #333;
      color: #e8e4de;
      font-family: 'Cormorant Garamond', Georgia, serif;
      font-size: 1rem;
      padding: 0.6rem 1rem;
      width: 100%;
      margin-bottom: 0.8rem;
      outline: none;
    }
    .gate-overlay input:focus {
      border-color: #666;
    }
    .gate-overlay button {
      background: #222;
      border: 1px solid #444;
      color: #e8e4de;
      font-family: 'Cormorant Garamond', Georgia, serif;
      font-size: 0.95rem;
      padding: 0.5rem 2rem;
      cursor: pointer;
      transition: background 0.2s;
    }
    .gate-overlay button:hover {
      background: #333;
    }
    .gate-error {
      color: #cc4444;
      font-size: 0.85rem;
      margin-top: 0.5rem;
      display: none;
    }
    .private-gate.unlocked .gate-overlay {
      display: none;
    }

    /* — Journal — */
    .journal-entry {
      margin-bottom: 3rem;
      padding-bottom: 2rem;
      border-bottom: 1px solid #1a1a1a;
    }
    .journal-date {
      font-size: 0.85rem;
      color: #666;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      margin-bottom: 0.5rem;
    }
    .journal-entry h3 {
      font-size: 1.15rem;
      font-weight: 600;
      margin-bottom: 0.5rem;
    }
    .journal-entry p {
      color: #b0aca6;
      font-size: 1rem;
    }
    .journal-tag {
      display: inline-block;
      font-size: 0.7rem;
      color: #888;
      border: 1px solid #333;
      padding: 0.1rem 0.5rem;
      margin-right: 0.4rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }
    .journal-tag.fix { border-color: #664444; color: #cc8888; }
    .journal-tag.feature { border-color: #446644; color: #88cc88; }
    .journal-tag.deploy { border-color: #444466; color: #8888cc; }
    .journal-tag.incident { border-color: #664400; color: #cc8844; }

    /* — Responsive — */
    @media (max-width: 720px) {
      html { font-size: 17px; }
      .container { padding: 2rem 1.25rem 4rem; }
      .wordmark { font-size: 2rem; }
      nav { margin-bottom: 3rem; }
      nav a { margin-right: 1.5rem; }
    }
  </style>
</head>
<body>
  <div class="container">
    <header>
      <div class="wordmark">
        <a href="/"><span class="wordmark-agent">agent</span><span class="wordmark-ic">-ic</span></a>
      </div>
      <nav>
        <a href="/essays/"{% if navActive == "essays" %} class="active"{% endif %}>Essays</a>
        <a href="/videos/"{% if navActive == "videos" %} class="active"{% endif %}>Videos</a>
        <a href="/journal/"{% if navActive == "journal" %} class="active"{% endif %}>Journal</a>
        <a href="/assets/"{% if navActive == "assets" %} class="active"{% endif %}>Assets</a>
        <a href="/about/"{% if navActive == "about" %} class="active"{% endif %}>About</a>
      </nav>
    </header>

    <main>
      {{ content | safe }}
    </main>

    <footer>
      &copy; 2026 agent-ic
    </footer>
  </div>
</body>
</html>
