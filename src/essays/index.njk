<h1>Essays</h1>

<p style="color:#999; font-size:1.05rem; margin-bottom:3rem;">Private meditations on building AI-native operations. Not thought leadership. Not content marketing. Notes from the bunker.</p>

<ul class="essay-list">
{%- for essay in collections.essays %}
  <li>
    <a href="{{ essay.url }}">{% if essay.data.tier == "commercial" %}<span style="color:#666; font-size:0.8em;" title="Encrypted — access code required">&#x1f512;</span> {% endif %}{{ essay.data.title }}</a>
    <div class="essay-meta">{% if essay.data.date %}{{ essay.data.date | isoDate }}{% endif %}{% if essay.data.tier == "commercial" %} &middot; <span style="color:#555;">Encrypted</span>{% endif %}</div>
  </li>
{%- endfor %}
</ul>
