<!-- ═══════ THE AGENT BRAIN ═══════ -->

<div class="asset">
  <h2 style="margin-bottom:0.3rem;">The Agent Brain: Tool-Use LLM Orchestration</h2>
  <div style="color:#555; font-size:0.8rem; text-transform:uppercase; letter-spacing:0.1em; margin-bottom:1.5rem;">All Agents &middot; agent_core.py</div>

  <p>Every agent — Locator, Landlord Rep, Ken — runs on the same core loop. The LLM receives the full conversation context, decides whether to call tools, and generates a response. Guardrails run <em>after</em> generation, not before. The LLM is the decision-maker. Tools are optional. The anti-determinism law forbids hardcoded decision trees — the LLM generates every response from scratch, with tools as capabilities it can invoke.</p>

  <pre style="background:#0a0a0a; border:1px solid #222; padding:1.5rem; font-size:0.8rem; line-height:1.6; color:#888; overflow-x:auto; margin:2rem 0;">
# Universal agent loop — from agent_core.py

def run_agent_turn(config: AgentConfig, context: dict) -> dict:

    # 1. Build system prompt (persona + tools + examples + rules)
    system_prompt = config.system_prompt_builder(context)

    # 2. Build message history for the LLM
    messages = [SystemMessage(content=system_prompt)]
    messages.append(HumanMessage(
        content=f"CONVERSATION SO FAR:\n{chat_history}"
    ))
    messages.append(HumanMessage(
        content=f"LATEST MESSAGE FROM LEAD:\n{last_message}"
    ))

    # 3. Bind tools to the LLM (Gemini function calling)
    llm = ChatGoogleGenerativeAI(model=config.model_name)
    llm_with_tools = llm.bind_tools(tool_declarations)

    # 4. Multi-round tool execution (up to 3 rounds)
    for round_idx in range(config.max_tool_rounds + 1):
        ai_msg = llm_with_tools.invoke(messages)

        if not ai_msg.tool_calls:
            break  # No tools needed — response is ready

        # Execute each tool call
        for tc in ai_msg.tool_calls:
            result = tool_map[tc["name"]].fn(**tc["args"])
            messages.append(ToolMessage(content=result))
            # Feed result back → LLM generates next round

    # 5. Post-generation guardrails
    for guard in config.guardrails:
        is_safe, reason = guard.check_fn(response_text, context)
        if not is_safe:
            return {"blocked": True, "reason": reason}

    return {"response": response_text, "tool_calls": all_tool_calls}</pre>

